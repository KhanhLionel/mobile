+package com.example.studentmanagenment.student_manage;
+
+import android.os.Bundle;
+import android.util.Log;
+import android.util.Patterns;
+import android.widget.Button;
+import android.widget.EditText;
+import android.widget.Toast;
+import androidx.appcompat.app.AppCompatActivity;
+import com.example.studentmanagenment.R;
+import com.example.studentmanagenment.api.ApiClient;
+import com.example.studentmanagenment.api.ApiService;
+import com.example.studentmanagenment.api.Student;
+import java.util.Map;
+import retrofit2.Call;
+import retrofit2.Callback;
+import retrofit2.Response;
+
+public class AddEditStudentActivity extends AppCompatActivity {
+    // Thay thế etPhone bằng etGpa
+    private EditText etMssv, etName, etEmail, etClassName, etGpa;
+    private Button btnSave;
+    private ApiService apiService;
+    private String studentId = null;
+
+    @Override
+    protected void onCreate(Bundle savedInstanceState) {
+        super.onCreate(savedInstanceState);
+        setContentView(R.layout.activity_add_student);
+
+        initViews();
+        // Sửa lại cho đúng tên hàm getApiService() trong file ApiClient của bạn
+        apiService = ApiClient.getApiService();
+
+        if (getIntent().hasExtra("STUDENT_ID")) {
+            studentId = getIntent().getStringExtra("STUDENT_ID");
+            fillDataForEdit();
+        }
+
+        btnSave.setOnClickListener(v -> {
+            if (validateInputs()) {
+                saveStudent();
+            }
+        });
+    }
+
+    private boolean validateInputs() {
+        String mssv = etMssv.getText().toString().trim();
+        String email = etEmail.getText().toString().trim();
+        String gpaStr = etGpa.getText().toString().trim();
+
+        if (mssv.isEmpty()) {
+            etMssv.setError("MSSV không được để trống");
+            return false;
+        }
+        if (!email.isEmpty() && !Patterns.EMAIL_ADDRESS.matcher(email).matches()) {
+            etEmail.setError("Email không đúng định dạng");
+            return false;
+        }
+        if (!gpaStr.isEmpty()) {
+            try {
+                double gpa = Double.parseDouble(gpaStr);
+                if (gpa < 0 || gpa > 10) {
+                    etGpa.setError("GPA phải nằm trong khoảng từ 0 - 10");
+                    return false;
+                }
+            } catch (NumberFormatException e) {
+                etGpa.setError("GPA không hợp lệ");
+                return false;
+            }
+        }
+        return true;
+    }
+
+    private void saveStudent() {
+        Student student = new Student();
+        student.setMssv(etMssv.getText().toString().trim());
+        student.setName(etName.getText().toString().trim());
+        student.setEmail(etEmail.getText().toString().trim());
+        student.setClassName(etClassName.getText().toString().trim());
+
+        // Xử lý nạp điểm GPA (mặc định là 0 nếu để trống)
+        String gpaStr = etGpa.getText().toString().trim();
+        if (!gpaStr.isEmpty()) {
+            student.setGpa(Double.parseDouble(gpaStr));
+        } else {
+            student.setGpa(0.0);
+        }
+
+        if (studentId == null) {
+            // CHỨC NĂNG THÊM MỚI [cite: 1]
+            apiService.addStudent(student).enqueue(new Callback<Map<String, String>>() {
+                @Override
+                public void onResponse(Call<Map<String, String>> call, Response<Map<String, String>> response) {
+                    if (response.isSuccessful()) {
+                        Toast.makeText(AddEditStudentActivity.this, "Thêm thành công!", Toast.LENGTH_SHORT).show();
+                        finish();
+                    }
+                }
+                @Override
+                public void onFailure(Call<Map<String, String>> call, Throwable t) {
+                    Toast.makeText(AddEditStudentActivity.this, "Lỗi kết nối", Toast.LENGTH_SHORT).show();
+                }
+            });
+        } else {
+            // CHỨC NĂNG CẬP NHẬT [cite: 1]
+            apiService.updateStudent(studentId, student).enqueue(new Callback<Student>() {
+                @Override
+                public void onResponse(Call<Student> call, Response<Student> response) {
+                    if (response.isSuccessful()) {
+                        Toast.makeText(AddEditStudentActivity.this, "Cập nhật thành công!", Toast.LENGTH_SHORT).show();
+                        finish();
+                    }
+                }
+                @Override
+                public void onFailure(Call<Student> call, Throwable t) {
+                    Toast.makeText(AddEditStudentActivity.this, "Lỗi cập nhật dữ liệu", Toast.LENGTH_SHORT).show();
+                }
+            });
+        }
+    }
+
+    // Hàm bổ trợ đọc dữ liệu cũ đổ lên Form khi ở chế độ Sửa (Tránh lỗi thiếu method)
+    private void fillDataForEdit() {
+        Log.d("EDIT_MODE", "Đang sửa sinh viên với ID: " + studentId);
+
+        // Thực hiện gọi mạng để lấy thông tin chi tiết sinh viên dựa theo ID
+        apiService.getStudentById(studentId).enqueue(new Callback<Student>() {
+            @Override
+            public void onResponse(Call<Student> call, Response<Student> response) {
+                if (response.isSuccessful() && response.body() != null) {
+                    Student currentStudent = response.body();
+
+                    // Điền dữ liệu nhận được vào form để người dùng chỉnh sửa
+                    etMssv.setText(currentStudent.getMssv());
+                    etName.setText(currentStudent.getName());
+                    etEmail.setText(currentStudent.getEmail());
+                    etClassName.setText(currentStudent.getClassName());
+                    etGpa.setText(String.valueOf(currentStudent.getGpa()));
+                } else {
+                    Toast.makeText(AddEditStudentActivity.this, "Không thể tải thông tin sinh viên", Toast.LENGTH_SHORT).show();
+                }
+            }
+
