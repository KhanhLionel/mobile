<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://tools.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFC">

    <RelativeLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#3F51B5"
        android:paddingHorizontal="24dp"
        android:paddingTop="28dp"
        android:paddingBottom="20dp"
        android:elevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_toLeftOf="@+id/btnConfigPercent"
            android:layout_alignParentLeft="true">

            <TextView
                android:id="@+id/tvStudentNameTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tên môn học"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Lập trình di động Firebase" />

            <TextView
                android:id="@+id/tvStudentIdTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mã môn học: ---"
                android:textColor="#C5CAE9"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                tools:text="Mã môn học: MH01" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:background="#28FFFFFF"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:backgroundTint="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ĐTB Lớp học phần: "
                    android:textColor="#FFFFFF"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tvTotalGpa"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.00"
                    android:textColor="#FFEB3B"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    tools:text="6,90" />
            </LinearLayout>
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnConfigPercent"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentRight="true"
            android:layout_alignParentTop="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/baseline_settings_24"
            android:contentDescription="Cấu hình phần trăm điểm"
            app:tint="#FFFFFF" />

    </RelativeLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cardSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/layoutHeader"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="4dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp">

        <androidx.appcompat.widget.SearchView
            android:id="@+id/searchViewStudent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:iconifiedByDefault="false"
            app:queryHint="Tìm sinh viên theo tên hoặc MSSV..." />
    </androidx.cardview.widget.CardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSubjectScores"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cardSearch"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="86dp"
        android:clipToPadding="false"
        tools:listitem="@layout/item_student" />

    <TextView
        android:id="@+id/tvEmptyMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardSearch"
        android:layout_centerInParent="true"
        android:layout_marginTop="100dp"
        android:text="Chưa có sinh viên nào trong lớp học phần này"
        android:textColor="#757575"
        android:textSize="15sp"
        android:textStyle="italic"
        android:visibility="gone"/>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddStudent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="24dp"
        android:contentDescription="Thêm sinh viên"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="#3F51B5"
        app:tint="#FFFFFF"
        android:elevation="8dp"
        app:fabSize="normal"/>

</RelativeLayout>